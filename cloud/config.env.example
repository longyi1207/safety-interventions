# Copy to cloud/config.env and fill in. All resources tagged Project=safety-interventions.

# AWS (required for launch.sh / teardown.sh)
export AWS_REGION=us-east-1
export AWS_KEY_NAME=your-ec2-keypair-name
export AWS_SECURITY_GROUP_ID=sg-xxxxxxxx   # must allow SSH 22 from your IP
export AWS_SUBNET_ID=subnet-xxxxxxxx       # optional; omit if default VPC OK

# GPU instance — g5.xlarge = 1x A10G 24GB (~$1/h on-demand, ~$0.4/h spot)
export AWS_INSTANCE_TYPE=g5.xlarge
export AWS_USE_SPOT=1                      # 1=spot (cheaper), 0=on-demand

# Deep Learning AMI (Ubuntu 22.04 + NVIDIA). Find latest in your region:
#   aws ec2 describe-images --owners amazon \
#     --filters "Name=name,Values=Deep Learning Base OSS Nvidia Driver GPU AMI (Ubuntu 22.04)*" \
#     --query 'Images | sort_by(@,&CreationDate) | [-1].ImageId' --output text
export AWS_AMI_ID=ami-xxxxxxxx

export GIT_REPO_URL=https://github.com/longyi1207/ai_lab.git
export GIT_BRANCH=main
export REMOTE_REPO_DIR='~/ai_lab/code/safety_interventions'

# SSH key created by cloud/setup_aws.sh
export AWS_KEY_FILE=cloud/.ssh/safety-interventions.pem
export AWS_KEY_NAME=safety-interventions

# Job options (passed to run_c2_iter.sh on instance)
export CONFIG=configs/qwen7b_harmbench.cloud.yaml
export BOOTSTRAP_JUDGE=0                   # set 1 if OPENAI_API_KEY on instance
export CONDITIONS=C0,C2
export HF_TOKEN=                           # optional; or huggingface-cli login on instance
